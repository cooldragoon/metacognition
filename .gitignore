# Python
__pycache__/
*.pyc
*.egg-info/

# Generated embeddings (regenerated by setup.sh)
*.npy

# Model files (downloaded by setup.sh)
expert-brain-server/models/

# Runtime artifacts
expert-brain-server/startup.log
*.pid
.server-*

# Local Claude Code config (personal, not shared)
.claude/settings.local.json
.claude/mcp.json
.mcp.json

# Brainstorm artifacts
.superpowers/

# PDFs and old docs
*.pdf
metacognition-product-document*.md

# ── Team sharing boundary ─────────────────────────────────────────────
# draft/*.md track as seed data (new user onboarding)
# live/*.md  track as team constraints (git shared)
# draft/*.npy + live/*.npy → regenerated by setup.sh
# index.md + log.md → rebuilt by setup.sh from .md files
#
# User's personal insights stay in draft/ (local, don't commit).
# When an insight is promoted to live/, git add + commit + push.

.cursor/insights/wiki/index.md
.cursor/insights/wiki/log.md
